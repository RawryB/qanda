// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // Avoid shipping Rust engine binaries (fixes Vercel packaging issues).
  // Requires a driver adapter at runtime (we use @prisma/adapter-pg + pg).
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("QANDA_DATABASE_URL")
}

model QandaForm {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  status            String            @default("draft") // draft|published|archived
  primaryColor      String            @default("#0D0D0D")
  accentColor       String            @default("#4A4744")
  transitionColor   String?
  primaryFont       String            @default("Syne")
  secondaryFont     String            @default("DM Sans")
  logoUrl           String?
  redirectUrl       String?
  zapierHookUrl     String?
  backgroundImageUrl String?
  introText         String?
  completionTitle   String?
  completionMessage String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  questions         QandaQuestion[]
  submissions       QandaSubmission[]
  logicRules        QandaLogicRule[]
  outcomeRules      QandaOutcomeRule[]
  webhookAttempts   QandaWebhookAttempt[]
}

model QandaQuestion {
  id        String        @id @default(cuid())
  formId    String
  order     Int
  type      String        // text|email|phone|yesno|multi|dropdown
  key       String        // stable identifier for piping later (e.g. first_name)
  title     String
  helpText  String?
  required  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  form      QandaForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  choices   QandaChoice[]
  answers   QandaAnswer[]
  sourceRules QandaLogicRule[] @relation("SourceQuestion")
  outcomeConditions QandaOutcomeCondition[]
  navSteps  QandaNavStep[]

  @@unique([formId, key]) // key unique within a form
  @@index([formId, order])
}

model QandaChoice {
  id         String        @id @default(cuid())
  questionId String
  order      Int
  value      String
  label      String

  question   QandaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, value])
  @@index([questionId, order])
}

model QandaSubmission {
  id          String        @id @default(cuid())
  formId      String
  status      String        @default("in_progress") // in_progress|completed
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  form        QandaForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers     QandaAnswer[]
  webhookAttempts QandaWebhookAttempt[]
  resolvedOutcome QandaResolvedOutcome?
  navSteps    QandaNavStep[]
  @@index([formId, startedAt])
}

model QandaAnswer {
  id           String         @id @default(cuid())
  submissionId String
  questionId   String
  valueText    String?
  valueJson    Json?
  submission   QandaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     QandaQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([submissionId, questionId])
}

model QandaLogicRule {
  id                  String        @id @default(cuid())
  formId              String
  sourceQuestionId    String
  operator            String        // equals | not_equals | contains | is_true | is_false
  compareValue        String?
  destinationQuestionId String?
  isEnd               Boolean       @default(false)
  priority            Int           @default(0) // lower number = evaluated first
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  form                QandaForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  sourceQuestion      QandaQuestion @relation("SourceQuestion", fields: [sourceQuestionId], references: [id], onDelete: Cascade)

  @@index([formId, sourceQuestionId, priority])
}

model QandaOutcomeRule {
  id               String                  @id @default(cuid())
  formId           String
  name             String
  priority         Int                     @default(0)
  isActive         Boolean                 @default(true)
  matchType        String                  @default("all") // all|any
  destinationType  String                  @default("redirect_url") // redirect_url
  destinationValue String
  segmentKey       String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  form             QandaForm               @relation(fields: [formId], references: [id], onDelete: Cascade)
  conditions       QandaOutcomeCondition[]
  resolvedOutcomes QandaResolvedOutcome[]

  @@index([formId, isActive, priority])
}

model QandaOutcomeCondition {
  id            String           @id @default(cuid())
  outcomeRuleId String
  questionId    String
  operator      String           @default("equals") // equals|in
  value         String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  outcomeRule   QandaOutcomeRule @relation(fields: [outcomeRuleId], references: [id], onDelete: Cascade)
  question      QandaQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([outcomeRuleId])
  @@index([questionId])
}

model QandaResolvedOutcome {
  id               String            @id @default(cuid())
  submissionId     String            @unique
  outcomeRuleId    String?
  destinationType  String?
  destinationValue String?
  segmentKey       String?
  resolvedAt       DateTime          @default(now())

  submission       QandaSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  outcomeRule      QandaOutcomeRule? @relation(fields: [outcomeRuleId], references: [id], onDelete: SetNull)

  @@index([outcomeRuleId])
}

model QandaWebhookAttempt {
  id           String   @id @default(cuid())
  submissionId String
  formId       String
  url          String
  attempt      Int
  statusCode   Int?
  success      Boolean  @default(false)
  error        String?
  createdAt    DateTime @default(now())

  submission   QandaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  form         QandaForm       @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
  @@index([formId, createdAt])
}

model QandaNavStep {
  id           String   @id @default(cuid())
  submissionId String
  questionId   String
  stepIndex    Int      // 0-based increasing
  createdAt    DateTime @default(now())

  submission   QandaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     QandaQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, stepIndex])
  @@index([submissionId, stepIndex])
  @@index([submissionId, questionId])
}
