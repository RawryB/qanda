// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  // Include Vercel/AWS Lambda runtime binary so the query engine is present at runtime.
  // "native" covers local dev; "rhel-openssl-3.0.x" matches the Vercel runtime in logs.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("QANDA_DATABASE_URL")
}

model QandaForm {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  status            String            @default("draft") // draft|published|archived
  redirectUrl       String?
  zapierHookUrl     String?
  backgroundImageUrl String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  questions         QandaQuestion[]
  submissions       QandaSubmission[]
  logicRules        QandaLogicRule[]
  webhookAttempts   QandaWebhookAttempt[]
}

model QandaQuestion {
  id        String        @id @default(cuid())
  formId    String
  order     Int
  type      String        // text|email|phone|yesno|multi|dropdown
  key       String        // stable identifier for piping later (e.g. first_name)
  title     String
  helpText  String?
  required  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  form      QandaForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  choices   QandaChoice[]
  answers   QandaAnswer[]
  sourceRules QandaLogicRule[] @relation("SourceQuestion")
  navSteps  QandaNavStep[]

  @@unique([formId, key]) // key unique within a form
  @@index([formId, order])
}

model QandaChoice {
  id         String        @id @default(cuid())
  questionId String
  order      Int
  value      String
  label      String

  question   QandaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, value])
  @@index([questionId, order])
}

model QandaSubmission {
  id          String        @id @default(cuid())
  formId      String
  status      String        @default("in_progress") // in_progress|completed
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  form        QandaForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers     QandaAnswer[]
  webhookAttempts QandaWebhookAttempt[]
  navSteps    QandaNavStep[]
  @@index([formId, startedAt])
}

model QandaAnswer {
  id           String         @id @default(cuid())
  submissionId String
  questionId   String
  valueText    String?
  valueJson    Json?
  submission   QandaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     QandaQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([submissionId, questionId])
}

model QandaLogicRule {
  id                  String        @id @default(cuid())
  formId              String
  sourceQuestionId    String
  operator            String        // equals | not_equals | contains | is_true | is_false
  compareValue        String?
  destinationQuestionId String?
  isEnd               Boolean       @default(false)
  priority            Int           @default(0) // lower number = evaluated first
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  form                QandaForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  sourceQuestion      QandaQuestion @relation("SourceQuestion", fields: [sourceQuestionId], references: [id], onDelete: Cascade)

  @@index([formId, sourceQuestionId, priority])
}

model QandaWebhookAttempt {
  id           String   @id @default(cuid())
  submissionId String
  formId       String
  url          String
  attempt      Int
  statusCode   Int?
  success      Boolean  @default(false)
  error        String?
  createdAt    DateTime @default(now())

  submission   QandaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  form         QandaForm       @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
  @@index([formId, createdAt])
}

model QandaNavStep {
  id           String   @id @default(cuid())
  submissionId String
  questionId   String
  stepIndex    Int      // 0-based increasing
  createdAt    DateTime @default(now())

  submission   QandaSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     QandaQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, stepIndex])
  @@index([submissionId, stepIndex])
  @@index([submissionId, questionId])
}
